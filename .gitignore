# Symbolication & obfuscation (release)
app.*.symbols
app.*.map.json

# Android build outputs (Studio)
/android/app/debug
/android/app/profile
/android/app/release

# Android release signing — never commit real keystores or passwords
/android/key.properties
/android/*.jks
/android/*.keystore

# Local dart-define bundle (copy from dart_defines.example.json)
/dart_defines.json

# Generic secrets (if you add scripts or env files)
.env
.env.*
!.env.example
secrets.json
*.pem

# iOS / Xcode / CocoaPods: see ios/.gitignore (Flutter template)
